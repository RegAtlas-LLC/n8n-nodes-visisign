{
  "name": "n8n-nodes-visisign",
  "version": "0.1.0",
  "description": "n8n community node for VisiSign — flat-rate e-signatures with API access",
  "keywords": [
    "n8n-community-node-package",
    "e-signatures",
    "esign",
    "visisign",
    "docusign-alternative"
  ],
  "license": "MIT",
  "homepage": "https://visisign.app",
  "author": {
    "name": "RegAtlas LLC",
    "email": "support@visisign.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RegAtlas-LLC/n8n-nodes-visisign.git"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "npx @n8n/node-cli lint",
    "release": "npx @n8n/node-cli release",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/VisiSignApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/VisiSign/VisiSign.node.js",
      "dist/nodes/VisiSign/VisiSignTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.23.0",
    "@types/node": "^20.0.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "typescript": "~5.4.0",
    "typescript-eslint": "^8.58.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
